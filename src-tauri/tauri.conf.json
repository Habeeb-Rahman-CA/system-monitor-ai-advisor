{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZOH",
  "version": "1.0.5",
  "identifier": "com.habee.zoh-ai-monitor",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/zoh-ai-monitor/browser"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ZOH: AI SYSTEM MONITOR",
        "width": 1000,
        "height": 800,
        "transparent": false,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1QjU2Q0JDMEQxMzhGMzUKUldRMWp4TU52R3kxbFF4UVJGa1g1ZGpLbWMrQjROeEdtaXpQSzlFbXVWZGduRDJrYW90bW1hejkK",
      "endpoints": [
        "https://raw.githubusercontent.com/Habeeb-Rahman-CA/zoh-ai-monitor/main/update.json"
      ]
    }
  }
}